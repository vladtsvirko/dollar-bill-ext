{
  "manifest_version": 3,
  "name": "Dollar Bill",
  "version": "1.0.0",
  "description": "Instantly convert prices on any webpage between your chosen currencies using official central bank rates.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://*.nbrb.by/*", "https://*.ecb.europa.eu/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/rates.js", "content.js"],
      "css": ["styles/injected.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
