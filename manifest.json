{
  "manifest_version": 3,
  "name": "Dollar Bill",
  "version": "1.0.0",
  "description": "Instantly convert prices on any webpage between your chosen currencies using official central bank rates.",
  "permissions": ["storage", "alarms", "activeTab"],
  "host_permissions": [
    "https://*.nbrb.by/*",
    "https://*.ecb.europa.eu/*",
    "https://*.nbp.pl/*",
    "https://*.bank.gov.ua/*",
    "https://*.cbr.ru/*",
    "https://*.cnb.cz/*",
    "https://*.tcmb.gov.tr/*",
    "https://*.bankofcanada.ca/*",
    "https://*.bcb.gov.br/*",
    "https://*.bankofengland.co.uk/*",
    "https://api.frankfurter.app/*",
    "https://api.hkma.gov.hk/*",
    "https://nationalbank.kz/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["core/currencies.js", "core/math.js", "core/rate-sources.js", "core/migrations.js", "core/settings.js", "core/i18n.js", "core/patterns.js", "core/rate-tables.js", "core/number-formatter.js", "core/format-utils.js", "core/rate-fetch.js", "core/rates.js", "content/scanner.js", "content/converter.js", "content/picker-bar.js", "content/observer.js", "content.js"],
      "css": ["styles/injected.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
